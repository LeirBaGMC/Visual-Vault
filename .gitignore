# ============================================================
# Visual Vault — .gitignore raíz (respaldo de los subproyectos)
# ============================================================

# --- Secretos / entorno (¡NUNCA subir!) ---
.env
*.env
!.env.example

# --- Base de datos local ---
*.db
database.db

# --- Python ---
venv/
.venv/
__pycache__/
*.py[cod]
*.egg-info/

# --- Node / frontend ---
node_modules/
dist/
dist-ssr/
.vite/
*.local

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Sistema operativo / editores ---
.DS_Store
Thumbs.db
.vscode/
.idea/
